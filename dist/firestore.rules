rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isStaff() {
      return request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'kitchen', 'delivery']);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      // Customers can create orders
      allow create: if request.auth != null && request.resource.data.customerId == request.auth.uid;
      // Customers can read and update their own orders
      allow read, update: if request.auth != null && resource.data.customerId == request.auth.uid;
      // Staff can read and update all orders
      allow read, update, delete: if isStaff();
    }

    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    match /tableLocks/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /tableDays/{tableDayId} {
      allow read, write: if true;
    }
    
    match /adminSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
